# Database
# Railway/Vercel production: prefer PostgreSQL.
# SQLite is fine for local dev and quick validation only.
DATABASE_URL=postgresql://user:password@host/dbname
POSTHUB_DATA_DIR=

# Public app URL used by Google OAuth callbacks
BASE_URL=

# JWT / Auth
# Generate a strong secret with:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-random-secret
JWT_ISSUER=posthub
JWT_AUDIENCE=posthub
ACCESS_TOKEN_TTL_SECONDS=43200

# Encryption (AES-256 key in base64)
# Generate with:
# python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY_B64=replace-with-a-base64-key

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-latest

# Initial admin user
POSTHUB_ADMIN_LOGIN=admin
POSTHUB_ADMIN_EMAIL=admin@example.com
POSTHUB_ADMIN_PASSWORD=replace-with-a-strong-password

# Google OAuth (optional)
SESSION_SECRET=replace-with-a-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cron worker secret (recommended on Vercel)
CRON_SECRET=replace-with-a-random-secret

# HTTP
WORDPRESS_TIMEOUT_SECONDS=30
HTTP_TIMEOUT_SECONDS=30
HTTP_INSECURE_SKIP_VERIFY=true

# Worker
# Local development: 1
# Vercel/serverless web: 0
# Railway web + dedicated worker: web=0 and worker command = python backend/worker_runner.py
POSTHUB_INLINE_WORKER=1

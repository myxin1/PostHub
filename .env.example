# ── Banco de Dados ─────────────────────────────────────────────────────────
# Para produção, use PostgreSQL (ex: Neon — neon.tech, gratuito)
DATABASE_URL=postgresql://user:password@host/dbname

# ── JWT / Autenticação ────────────────────────────────────────────────────
# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque-por-uma-chave-secreta-aleatoria
JWT_ISSUER=posthub
JWT_AUDIENCE=posthub
ACCESS_TOKEN_TTL_SECONDS=43200

# ── Criptografia (chave AES-256 em base64) ────────────────────────────────
# Gere: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY_B64=sua-chave-base64-aqui

# ── Google Gemini AI ──────────────────────────────────────────────────────
GEMINI_API_KEY=sua-chave-gemini
GEMINI_MODEL=gemini-1.5-flash-latest

# ── Usuário Admin inicial ─────────────────────────────────────────────────
POSTHUB_ADMIN_LOGIN=admin
POSTHUB_ADMIN_EMAIL=admin@exemplo.com
POSTHUB_ADMIN_PASSWORD=troque-esta-senha

# ── OAuth Google (opcional) ───────────────────────────────────────────────
SESSION_SECRET=troque-por-uma-chave-secreta-aleatoria
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── HTTP ──────────────────────────────────────────────────────────────────
WORDPRESS_TIMEOUT_SECONDS=30
HTTP_TIMEOUT_SECONDS=30
HTTP_INSECURE_SKIP_VERIFY=true

# ── Worker ────────────────────────────────────────────────────────────────
POSTHUB_INLINE_WORKER=1
